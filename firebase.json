{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.firebaserc", "**/*.md", "**/*.txt", "**/*.command", "**/firestore.rules", "**/node_modules/**"],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
